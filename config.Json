{
  "workflowApiVersion": "1.1",
  "metaData": {
    "icon": "https://via.placeholder.com/40",
    "category": "message"
  },
  "type": "REST",
  "lang": {
    "en-US": {
      "name": "Send to Caleida",
      "description": "Envía lead a Caleida (WhatsApp IA)"
    }
  },
  "arguments": {
    "execute": {
      "inArguments": [
        { "contactKey": "{{Contact.Key}}" },
        { "phone": "{{Contact.Attribute.DE.Phone}}" },
        { "name": "{{Contact.Attribute.DE.Name}}" }
      ],
      "url": "https://sfmc-mock-customactivityys-1.onrender.com/execute",
      "verb": "POST",
      "format": "json",
      "timeout": 10000
    }
  },
  "configurationArguments": {
    "save": {
      "url": "https://sfmc-mock-customactivityys-1.onrender.com/save",
      "verb": "POST"
    },
    "publish": {
      "url": "https://sfmc-mock-customactivityys-1.onrender.com/publish",
      "verb": "POST"
    },
    "validate": {
      "url": "https://sfmc-mock-customactivityys-1.onrender.com/validate",
      "verb": "POST"
    }
  },
  "wizardSteps": [
    { "label": "Configurar", "key": "step1" }
  ],
  "userInterfaces": {
    "configModal": {
      "height": 400,
      "width": 1000,
      "fullscreen": false
    }
  }
